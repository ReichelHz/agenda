# ─────────────────────────────────────────────
# Variables de entorno — TerapiasVida Frontend
# ─────────────────────────────────────────────
# Copiá este archivo como .env y completá los valores.
# Las variables sin prefijo NEXT_PUBLIC_ solo son accesibles
# del lado del servidor (Route Handlers). Nunca expongas
# secretos con el prefijo NEXT_PUBLIC_.

# URL del backend Spring Boot
# Solo disponible en el servidor (Route Handlers / BFF).
# En producción reemplazá con la URL real del backend.
BACKEND_URL=http://localhost:8081

# Entorno de ejecución (development | production | test)
NODE_ENV=development
